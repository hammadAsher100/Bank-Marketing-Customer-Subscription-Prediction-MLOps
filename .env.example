# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES FOR LOCAL DEVELOPMENT & DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════

# === LOCAL DEVELOPMENT ===
# For running locally, leave as is (Streamlit will connect to localhost:8000)
API_URL=http://localhost:8000

# === STREAMLIT CLOUD DEPLOYMENT ===
# Replace with your deployed backend URL
# Example: https://bank-marketing-api-xxx.onrender.com
# API_URL=https://your-backend-name.onrender.com

# === RENDER DEPLOYMENT ===
# Backend service will run on port 8000 (handled by app_render.py)
# Frontend will use the API_URL above to connect
# PORT=8000

# === MLflow Tracking ===
# MLFLOW_TRACKING_URI=http://localhost:5000

# === DVC Remote Storage ===
# DVC_REMOTE_URL=s3://your-bucket-name

# === Optional: API Authentication ===
# API_KEY=your-secret-key-here
